# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Cohere API key — get a free key at dashboard.cohere.com
COHERE_API_KEY=your-cohere-key-here

# Database URL
# Local dev: leave as-is (SQLite file created automatically)
# Railway: set to your Railway Postgres URL (postgres://... is rewritten automatically)
DATABASE_URL=sqlite:///./fpl.db
